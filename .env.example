# ============================================
# Company Analysis IVA - Environment Variables
# ============================================

# Groq API Key (FREE - get yours at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_key_here

# LLM Model (Groq free tier options: llama-3.3-70b-versatile, llama-3.1-8b-instant, openai/gpt-oss-120b)
LLM_MODEL=llama-3.3-70b-versatile

# ChromaDB uses local sentence-transformer embeddings (no API key needed)
# Embedding model is configured automatically by ChromaDB

# Server
HOST=0.0.0.0
PORT=8000
